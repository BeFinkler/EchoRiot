<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EchoRiot - Playlists</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- User Status Widget -->
<div id="userStatus" class="user-status fade-in">
  <h5>Status da Conta</h5>
  <p id="userStatusText">Verificando...</p>
</div>

<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">🎸 EchoRiot</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm">Home</a>
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/register" class="btn btn-outline-light btn-sm">Registrar</a>
      </div>
    </div>
  </div>
</nav>

<div class="page-header card card-body">
  <h1>🎵 Minhas Playlists</h1>
  <p class="lead">Crie, organize e adicione músicas às suas playlists de forma clara e rápida.</p>
</div>

<div class="container mt-5">

  <!-- Statistics Section -->
  <div id="statsContainer" class="stats-container" style="display: none;">
    <div class="stat-card">
      <div class="stat-number" id="totalPlaylists">0</div>
      <div class="stat-label">Playlists</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" id="totalSongs">0</div>
      <div class="stat-label">Músicas</div>
    </div>
      <div class="stat-card">
      <div class="stat-number" id="recentPlaylists">0</div>
      <div class="stat-label">Esta Semana</div>
    </div>
  </div>

  <!-- Search Section -->
  <div class="search-container">
    <div class="row">
      <div class="col-md-8">
        <input type="text" id="searchInput" class="form-control" placeholder="Buscar playlists por nome ou descrição...">
      </div>
      <div class="col-md-4">
        <select id="sortSelect" class="form-control">
          <option value="createdAt">Ordenar por Data</option>
          <option value="name">Ordenar por Nome</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Create Playlist Section -->
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">✨ Criar Nova Playlist</h5>
    </div>
    <div class="card-body">
      <div class="row gx-3 gy-3">
        <div class="col-md-6">
          <label for="name" class="form-label fw-bold">Nome da Playlist</label>
          <div class="input-group">
            <span class="input-group-text">🎧</span>
            <input id="name" class="form-control" placeholder="Ex: Hits de Rock" aria-label="Nome da playlist">
          </div>
          <small class="text-muted">Escolha um nome que ajude a identificar a playlist.</small>
        </div>
        <div class="col-md-6">
          <label for="description" class="form-label fw-bold">Descrição (Opcional)</label>
          <div class="input-group">
            <span class="input-group-text">📝</span>
            <input id="description" class="form-control" placeholder="Ex: Rock clássico dos anos 2000" aria-label="Descrição da playlist">
          </div>
          <small class="text-muted">Adicione um tema ou objetivo breve para a playlist.</small>
        </div>
      </div>
      <div class="mt-3">
        <button onclick="createPlaylist()" class="btn btn-primary">Criar Playlist</button>
      </div>
    </div>
  </div>

  <!-- Playlists Section -->
  <div class="mt-5">
    <h2 class="mb-4">🎶 Suas Playlists</h2>
    <div id="playlistsContainer">
      <div class="text-center">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Carregando...</span>
        </div>
        <p class="mt-2">Carregando suas playlists...</p>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>