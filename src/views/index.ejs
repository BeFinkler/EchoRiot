<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EchoRiot - Playlists</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">🎸 EchoRiot</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm">Home</a>
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/register" class="btn btn-outline-light btn-sm">Registrar</a>
      </div>
    </div>
  </div>
</nav>

<div class="page-header">
  <div class="container">
    <h1>Minhas Playlists 🎵</h1>
    <p>Gerencie e crie suas melhores playlists aqui</p>
  </div>
</div>

<div class="container mt-5">
  <div class="form-section">
    <h2>Criar Nova Playlist</h2>
    
    <div class="mb-3">
      <label for="name" class="form-label">Nome da Playlist</label>
      <input id="name" class="form-control" placeholder="Digite o nome da sua playlist">
    </div>
    
    <div class="mb-3">
      <label for="description" class="form-label">Descrição (Opcional)</label>
      <textarea id="description" class="form-control" rows="2" placeholder="Descreva sua playlist"></textarea>
    </div>
    
    <button onclick="createPlaylist()" class="btn btn-primary">Criar Playlist</button>
  </div>

  <div class="mt-5">
    <h2 class="mb-4">Suas Playlists</h2>
    <ul id="list" class="mt-4"></ul>
  </div>
</div>

<script src="/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>