<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registrar - EchoRiot</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">🎸 EchoRiot</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm">Home</a>
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        <a href="/register" class="btn btn-outline-light btn-sm">Registrar</a>
      </div>
    </div>
  </div>
</nav>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="form-section">
        <h2 class="text-center mb-4">Crie sua conta</h2>
        
        <div class="form-group">
          <label for="name" class="form-label">Nome Completo</label>
          <input id="name" class="form-control" placeholder="Seu nome completo">
        </div>
        
        <div class="form-group">
          <label for="email" class="form-label">Email</label>
          <input id="email" class="form-control" placeholder="seu@email.com" type="email">
        </div>
        
        <div class="form-group">
          <label for="password" class="form-label">Senha</label>
          <input id="password" type="password" class="form-control" placeholder="Crie uma senha forte">
        </div>
        
        <button onclick="register()" class="btn btn-primary w-100 mb-3">Cadastrar</button>
        
        <div class="form-divider">
          Já tem conta? <a href="/login">Entre aqui</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>